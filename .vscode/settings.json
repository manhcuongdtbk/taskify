{
  "js/ts.tsdk.path": "node_modules/typescript/lib", // https://nextjs.org/docs/app/api-reference/config/typescript#ide-plugin

  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // https://marketplace.visualstudio.com/items?itemName=bradlc.vscode-tailwindcss#recommended-vs-code-settings
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },

  // https://marketplace.visualstudio.com/items?itemName=esbenp.prettier-vscode#using-code-actions-on-save
  "editor.codeActionsOnSave": {
    "source.fixAll.prettier": "explicit",
    "source.fixAll.eslint": "explicit"
  },

  "editor.linkedEditing": true,
  "editor.tabSize": 2
}
